# Kiseki 3-node Raft cluster — Node 1 (seed).
#
# Deploy nodes 1-3 on separate machines. Node 1 bootstraps the cluster;
# nodes 2-3 join as followers. Start node 1 first, then 2 and 3.
#
# Usage:
#   env $(cat examples/cluster-3node.env.node1 | grep -v '^#') kiseki-server

# --- Cluster identity ---
KISEKI_NODE_ID=1
KISEKI_BOOTSTRAP=true
KISEKI_RAFT_PEERS=1=10.0.0.1:9300,2=10.0.0.2:9300,3=10.0.0.3:9300
KISEKI_RAFT_ADDR=0.0.0.0:9300

# --- Persistence ---
KISEKI_DATA_DIR=/var/lib/kiseki

# --- Protocol listeners ---
KISEKI_S3_ADDR=0.0.0.0:9000
KISEKI_NFS_ADDR=0.0.0.0:2049
KISEKI_DATA_ADDR=0.0.0.0:9100
KISEKI_ADVISORY_ADDR=0.0.0.0:9101
KISEKI_ADVISORY_STREAM_ADDR=0.0.0.0:9102
KISEKI_METRICS_ADDR=0.0.0.0:9090

# --- Raw block devices (optional) ---
# Uncomment to use raw devices instead of filesystem-backed storage.
# Kiseki manages these directly via DeviceBackend — no filesystem needed.
# KISEKI_RAW_DEVICES=/dev/sdb,/dev/sdc,/dev/sdd

# --- Logging ---
RUST_LOG=info
