# Kiseki client configuration.
#
# The client binary (kiseki-client) supports FUSE mount and cache management.
#
# FUSE mount:
#   env $(cat examples/client.env | grep -v '^#') \
#     kiseki-client mount --endpoint 10.0.0.1:9100 --mountpoint /mnt/kiseki
#
# Cache status:
#   kiseki-client cache --status --cache-dir /cache

# --- Cache ---
# Mode: "organic" (evict LRU), "pinned" (no eviction), "bypass" (no cache)
KISEKI_CACHE_MODE=organic
KISEKI_CACHE_DIR=/cache

# L1: in-memory read cache (per-process, lost on restart)
KISEKI_CACHE_L1_MAX=268435456

# L2: on-disk cache (survives restart, shared across mounts)
# Size in bytes — 50 GB default, increase for large working sets
KISEKI_CACHE_L2_MAX=53687091200

# --- Metadata ---
# How long to trust cached metadata before re-checking with the server.
# Lower = more consistent, higher = fewer round-trips.
KISEKI_CACHE_META_TTL_MS=5000
