# Kiseki single-node server — persistent storage, no clustering.
#
# Usage:
#   env $(cat examples/single-node.env | grep -v '^#') kiseki-server
#
# This is the simplest deployment: one node with all protocols enabled,
# data persisted to /var/lib/kiseki. Suitable for development, testing,
# or small single-machine workloads.

# --- Persistence ---
KISEKI_DATA_DIR=/var/lib/kiseki
KISEKI_BOOTSTRAP=true

# --- Protocol listeners ---
KISEKI_S3_ADDR=0.0.0.0:9000
KISEKI_NFS_ADDR=0.0.0.0:2049
KISEKI_DATA_ADDR=0.0.0.0:9100
KISEKI_ADVISORY_ADDR=0.0.0.0:9101
KISEKI_ADVISORY_STREAM_ADDR=0.0.0.0:9102
KISEKI_METRICS_ADDR=0.0.0.0:9090

# --- Logging ---
RUST_LOG=info
